# TheTVDB v4 API credentials (server-side only  never exposed to the browser)
# Get a key at https://thetvdb.com/dashboard/account/apikey
TVDB_API_KEY=your-tvdb-v4-api-key
# Only required for "user-supported" subscriber keys; leave blank otherwise.
TVDB_PIN=

# Google Analytics 4 measurement id (the G-XXXXXXXXXX string, not the property number).
# Optional  analytics is skipped if this is empty.
PUBLIC_GA4_ID=
